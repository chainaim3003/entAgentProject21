# ACTUS Hedge Advisor — backend environment.
# Copy this file to `.env` and fill in real values.
# All variables marked REQUIRED are validated on startup; the app fails fast if missing.

# ──────────────────────────────────────────────────────────────────────
# REQUIRED — Reasoning agents (Gemini)
# ──────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=AIzaSyDdvJXm2h5A0nO7bvgrjgRiV8gQFhsTBB0
GEMINI_MODEL=gemini-2.5-flash

# ──────────────────────────────────────────────────────────────────────
# REQUIRED — The knot (DRAPS MCP server)

# Where the DRAPS run_simulation MCP tool is served.
# Example (local dev):  http://localhost:3001
# Example (deployed):   https://draps.example.com
# ──────────────────────────────────────────────────────────────────────
DRAPS_MCP_URL=http://localhost:4000

# ──────────────────────────────────────────────────────────────────────
# REQUIRED — Right wing (ACTUS-Mentor REST API)
# Where the /generate-xbrl-report endpoint is served.
# Example:  http://52.73.253.140:8000
# ──────────────────────────────────────────────────────────────────────
ACTUS_MENTOR_URL=http://localhost:8001

# ──────────────────────────────────────────────────────────────────────
# OPTIONAL — Persistence
# Both default to local SQLite files in the backend working directory.
# Swap to Postgres for production (langgraph-checkpoint-postgres + SQLAlchemy URL).
# ──────────────────────────────────────────────────────────────────────
CHECKPOINT_DB_URL=sqlite:///./checkpoints.db
MEMORY_DB_URL=sqlite:///./memory.db

# ──────────────────────────────────────────────────────────────────────
# OPTIONAL — Server
# ──────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ──────────────────────────────────────────────────────────────────────
# OPTIONAL — Workflow limits
# ──────────────────────────────────────────────────────────────────────
MAX_VALIDATOR_RETRIES=3

# ────────────────────────────────────────────────────────────────────
# OPTIONAL — ACTUS-Mentor API key.
# Required only if ACTUS-Mentor has API_SECRET_KEY env var set (auth enabled).
# Leave blank when running ACTUS-Mentor locally without auth.
# ────────────────────────────────────────────────────────────────────
ACTUS_MENTOR_API_KEY=
